{
  "name": "vue-iconify",
  "version": "1.0.12",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jianvey/vue-iconify.git"
  },
  "bugs": "https://github.com/Jianvey/vue-iconify/issues",
  "homepage": "https://github.com/Jianvey/vue-iconify",
  "author": "Jianvey <Jianvey@outlook.com> (https://daixu.cn/)",
  "description": "This is a component for introducing SVG icons in your Vue.js project, which allows you to easily integrate SVG icons into your application and add custom styles and animations to them.",
  "keywords": [
    "Jianvey",
    "svg",
    "icon",
    "vue-svg",
    "vue-icon"
  ],
  "main": "./dist/index.umd.js",
  "module": "./dist/index.es.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "require": "./dist/index.umd.js",
      "import": "./dist/index.es.js"
    },
    "./global": "./dist/src/global.d.ts"
  },
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "prettier": "prettier --write .",
    "commit": "git-cz",
    "prepare": "husky"
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "dependencies": {
    "@vueuse/core": "^14.2.1",
    "vue": "^3.5.29"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@commitlint/cz-commitlint": "^20.4.3",
    "@commitlint/prompt-cli": "^20.4.3",
    "@rushstack/eslint-patch": "^1.16.1",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.0",
    "commitizen": "^4.3.1",
    "eslint": "^10.0.2",
    "eslint-plugin-vue": "^10.8.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "sass": "~1.97.3",
    "terser": "^5.46.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-progress": "^0.0.7",
    "vue-tsc": "^3.2.5"
  }
}
